<?xml version="1.0" encoding="utf-8"?>
<!--
	THIET LAP HE THONG
	LimitAccount: Gioi han tai khoan
		- MaxCCU: Gioi han CCU
		- LimitAccountPerIPAddress: Gioi han so tai khoan dang nhap tren mot dia chi IP
	MonsterAI: Thiet lap AI quai
		- EnableMonsterAIRandomMove: Mo luong AI tu di chuyen
		- EnableMonsterAI: Mo luong thuc thi AI
	Threading: Thiet lap luong
		- MaxUpdateGridThread: So luong toi da cap nhat tam nhin cua nguoi choi
		- MaxPlayerStoryBoardThread: So luong thuc thi StoryBoard toi da cua nguoi choi
		- MaxMonsterTimer: So luong thuc thi cua quai
		- MaxBuffTimer: So luong thuc thi cua Buff
		- MaxPetTimer: So luong thuc thi cua Pet
		- MaxTraderCarriageTimer: So luong thuc thi cua xe tieu
	GameConfig: Thiet lap tro choi
		- LimitLevel: Gioi han cap
		- MonsterKilledToSpawnElite: Tong so quai sau khi tieu diet du se xuat hien tinh anh o moi bai
		- MonsterKilledToSpawnLeader: Tong so quai sau khi tieu diet du se xuat hien thu linh o moi bai
		- MaxFireCampAndElitePerZone: So luong lua trai dong thoi cung tinh anh toi da co the ton tai dong thoi tren cung 1 bai
		- EnableCrossServer: Mo lien Server
	Captcha: Thiet lap Captcha
		- EnableCaptcha: Kich hoat Captcha
		- EnableCaptchaForIOS: Kich hoat Captcha cho cac thiet bi iOS
		- CaptchaAppearMinPeriod: Thoi gian toi thieu moi lan xuat hien Captcha
		- CaptchaAppearMaxPeriod: Thoi gian toi da moi lan xuat hien Captcha
		- CaptchaTeamPlayersOnly: Chi hien Captcha voi nguoi choi co nhom
		- CaptchaAppearFromTime: Thoi gian (gio:phut) bat dau xuat hien Captcha trong ngay
		- CaptchaAppearToTime: Thoi gian (gio:phut) ket thuc xuat hien Captcha trong ngay
		- CaptchaExpAddPerLevel: Phan thuong kinh nghiem khi tra loi dung Captcha
		- CaptchaBoundMoneyAddPerLevel: Phan thuong bac khoa khi tra loi dung Captcha
-->
<ServerConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
	<ServerRate MoneyRate="1.0" ExpRate="2.0" />
	<LimitAccount MaxCCU="1000" LimitAccountPerIPAddress="30" />
	<MonsterAI EnableMonsterAIRandomMove="true" EnableMonsterAI="true" />
	<Threading MaxUpdateGridThread="5" MaxPlayerStoryBoardThread="5" MaxMonsterTimer="5" MaxBuffTimer="1" MaxPetTimer="3" MaxTraderCarriageTimer="1" MaxBotTimer="1" />
	<GameConfig LimitLevel="200" MonsterKilledToSpawnElite="300" MonsterKilledToSpawnLeader="600" MaxFireCampAndElitePerZone="2" />
	<Captcha EnableCaptcha="false" EnableCaptchaForIOS="false" CaptchaAppearMinPeriod="30000" CaptchaAppearMaxPeriod="36000" CaptchaTeamPlayersOnly="false" CaptchaAppearFromTime="9:00" CaptchaAppearToTime="23:59" CaptchaExpAddPerLevel="500" CaptchaBoundMoneyAddPerLevel="100" />
	<CrossServer EnableCrossServer="true" />
</ServerConfig>